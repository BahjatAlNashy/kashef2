# ============================================
# ملف إعدادات Railway - انسخ هذا المحتوى إلى Variables في Railway
# ============================================

# ============================================
# إعدادات التطبيق العامة
# ============================================
# [تغيير مطلوب] اسم التطبيق
APP_NAME="نظام كشوفات الصيانة والمستودع"

# [لا تغير] بيئة الإنتاج
APP_ENV=production

# [تغيير مطلوب] مفتاح التطبيق - أنشئ واحداً جديداً بتشغيل:
# php artisan key:generate --show
# ثم انسخ القيمة هنا
APP_KEY=base64:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# [لا تغير] تعطيل وضع التصحيح في الإنتاج
APP_DEBUG=false

# [تغيير تلقائي] Railway يضيف هذا تلقائياً
APP_URL=${{RAILWAY_STATIC_URL}}

# ============================================
# إعدادات قاعدة البيانات
# ============================================
# [لا تغير]
DB_CONNECTION=mysql

# [تغيير تلقائي] إذا أضفت MySQL في Railway، هذه القيم تُملأ تلقائياً
# أو استبدلها يدوياً إذا استخدمت قاعدة بيانات خارجية
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ============================================
# إعدادات التوقيت واللغة
# ============================================
# [لا تغير] التوقيت الصحيح للمنطقة الزمنية
APP_TIMEZONE=Asia/Damascus
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

# ============================================
# إعدادات الجلسات والتخزين
# ============================================
# [لا تغير]
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
CACHE_PREFIX=

# ============================================
# إعدادات البريد (اختياري - يمكن تركه فارغاً)
# ============================================
# [اختياري] اتركه فارغاً إذا لم تريد إرسال بريد
MAIL_MAILER=log
MAIL_HOST=null
MAIL_PORT=null
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# إعدادات السجل والتصحيح
# ============================================
# [لا تغير]
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ============================================
# ============================================
# الأوامر المطلوبة تشغيلها في Railway Terminal
# ============================================
# بعد إضافة المتغيرات أعلاه، شغل هذه الأوامر في Terminal:
#
# 1. تثبيت الاعتماديات:
#    composer install --no-dev --optimize-autoloader
#
# 2. تشغيل Migrations:
#    php artisan migrate --force
#
# 3. (اختياري) إنشاء مستخدم مدير:
#    php artisan tinker
#    >>> $user = new App\Models\User();
#    >>> $user->name = 'المدير';
#    >>> $user->email = 'manager@example.com';
#    >>> $user->password = bcrypt('password123');
#    >>> $user->role = 'manager';
#    >>> $user->save();
#
# ============================================
